#!/bin/sh
# pre-commit hook SVN
# Bloque les fichiers/dossiers interdits avant qu'ils entrent dans le depot
# A placer dans : svnmaster/hooks/pre-commit (sans extension sur Linux/Mac)
# ou pre-commit.bat sur Windows

REPOS="$1"
TXN="$2"

SVNLOOK=/usr/bin/svnlook

# Liste des patterns interdits
FORBIDDEN="node_modules
\.git
venv
dist
build
\.next
\.cache
sauvegardes
svnmaster
__pycache__
\.env
Thumbs\.db
\.DS_Store"

# Recuperer la liste des fichiers du commit
CHANGED=$($SVNLOOK changed -t "$TXN" "$REPOS" | awk '{print $2}')

for path in $CHANGED; do
    for pattern in $FORBIDDEN; do
        if echo "$path" | grep -qE "(^|/)$pattern(/|$)"; then
            echo "COMMIT REFUSE : '$path' contient un element interdit ('$pattern')." >&2
            echo "Retire ce fichier/dossier du commit et reessaie." >&2
            exit 1
        fi
    done
done

exit 0
