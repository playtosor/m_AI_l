@echo off
echo === Retrait de VillageBuilder\.git et node_modules du depot SVN ===
echo (les fichiers locaux sont conserves)
echo.

REM --- Retirer .git de VillageBuilder ---
svn delete --keep-local "C:\dev\VillageBuilder\.git"
echo [OK] .git retire du depot

REM --- Retirer node_modules si present dans VillageBuilder ---
if exist "C:\dev\VillageBuilder\node_modules" (
    svn delete --keep-local "C:\dev\VillageBuilder\node_modules"
    echo [OK] node_modules retire du depot
) else (
    echo [SKIP] node_modules absent dans VillageBuilder
)

echo.
echo === Verification status ===
svn status "C:\dev\VillageBuilder"

pause
