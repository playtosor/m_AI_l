@echo off
echo === Configuration svn:ignore (partie 2 - fix) ===

REM Creer le fichier d'ignore pour les projets React/Node
(
  echo node_modules
  echo dist
  echo build
  echo .next
  echo .cache
) > "%TEMP%\node_ignore.txt"

REM Creer le fichier d'ignore pour VillageBuilder
(
  echo .git
  echo node_modules
  echo dist
  echo build
) > "%TEMP%\village_ignore.txt"

REM --- labyFlecheReact ---
svn propset svn:ignore -F "%TEMP%\node_ignore.txt" "C:\dev\labyFlecheReact"
echo [OK] labyFlecheReact

REM --- LABY_CHRONOClaude1 ---
svn propset svn:ignore -F "%TEMP%\node_ignore.txt" "C:\dev\LABY_CHRONOClaude1"
echo [OK] LABY_CHRONOClaude1

REM --- DEV_labyfleche ---
svn propset svn:ignore -F "%TEMP%\node_ignore.txt" "C:\dev\DEV_labyfleche"
echo [OK] DEV_labyfleche

REM --- VillageBuilder ---
svn propset svn:ignore -F "%TEMP%\village_ignore.txt" "C:\dev\VillageBuilder"
echo [OK] VillageBuilder

del "%TEMP%\node_ignore.txt"
del "%TEMP%\village_ignore.txt"

echo.
echo === Verification ===
echo -- labyFlecheReact --
svn propget svn:ignore "C:\dev\labyFlecheReact"
echo -- VillageBuilder --
svn propget svn:ignore "C:\dev\VillageBuilder"

pause
