@echo off
REM pre-commit hook SVN (Windows)
REM Bloque les fichiers/dossiers interdits avant qu'ils entrent dans le depot
REM A placer dans : svnmaster\hooks\pre-commit.bat

set REPOS=%1
set TXN=%2

set SVNLOOK=svnlook

REM Recuperer les fichiers du commit dans un fichier temporaire
%SVNLOOK% changed -t %TXN% %REPOS% > "%TEMP%\svn_changed.txt" 2>&1
if errorlevel 1 (
    echo Erreur svnlook >&2
    exit /b 1
)

REM Patterns interdits (simples, sans ambiguite de sous-chaine)
set FORBIDDEN=node_modules venv dist build .next .cache sauvegardes svnmaster __pycache__

REM Patterns interdits traites separement pour eviter les faux positifs
REM .git  -> matcher uniquement /.git/ ou chemin se terminant par /.git
REM .env  -> matcher uniquement /.env/ ou chemin se terminant par /.env

for /f "tokens=2" %%F in (%TEMP%\svn_changed.txt) do (

    REM --- Patterns simples ---
    for %%P in (%FORBIDDEN%) do (
        echo %%F | findstr /i /c:"%%P" > nul
        if not errorlevel 1 (
            echo COMMIT REFUSE : '%%F' contient un element interdit ^(%%P^). >&2
            echo Retire ce fichier/dossier du commit et reessaie. >&2
            del "%TEMP%\svn_changed.txt"
            exit /b 1
        )
    )

    REM --- .git : exige /. git/ ou fin de chemin /.git ---
    echo %%F | findstr /i /r /c:"[/\\]\.git[/\\]" /c:"[/\\]\.git$" > nul
    if not errorlevel 1 (
        echo COMMIT REFUSE : '%%F' contient un element interdit ^(.git^). >&2
        echo Retire ce fichier/dossier du commit et reessaie. >&2
        del "%TEMP%\svn_changed.txt"
        exit /b 1
    )

    REM --- .env : exige /.env/ ou fin de chemin /.env ---
    echo %%F | findstr /i /r /c:"[/\\]\.env[/\\]" /c:"[/\\]\.env$" > nul
    if not errorlevel 1 (
        echo COMMIT REFUSE : '%%F' contient un element interdit ^(.env^). >&2
        echo Retire ce fichier/dossier du commit et reessaie. >&2
        del "%TEMP%\svn_changed.txt"
        exit /b 1
    )

)

del "%TEMP%\svn_changed.txt"
exit /b 0
