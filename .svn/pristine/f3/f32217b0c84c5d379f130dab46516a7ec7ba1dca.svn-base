@echo off
setlocal
chcp 65001 > nul
echo ========================================
echo       SVN Automator Pro - Mode IA
echo ========================================

echo [1/5] Mise a jour du depot...
svn update
if %ERRORLEVEL% neq 0 (
    echo [ERREUR] Impossible de mettre a jour le depot.
    pause
    exit /b 1
)

echo.
set /p MSG="Message de commit : "
if "%MSG%"=="" (
    echo [ERREUR] Le message est vide. Operation annulee.
    pause
    exit /b 1
)

echo.
echo [2/5] Indexation des modifications...

svn add . --force --auto-props > nul 2>&1

svn status > svn_status_tmp.txt 2>&1
for /f "tokens=1,*" %%a in (svn_status_tmp.txt) do (
    if "%%a"=="!" svn delete "%%b" > nul 2>&1
)
del svn_status_tmp.txt > nul 2>&1

echo.
echo ========================================
echo MODIFICATIONS PREVUES :
echo ========================================
svn status
echo ========================================
echo.

set /p CONFIRM="Confirmer et envoyer (O/N) ? : "
if /i not "%CONFIRM%"=="O" (
    echo [ANNULE] Aucun changement effectue.
    pause
    exit /b 0
)

echo.
echo [3/5] Envoi vers le serveur...
svn commit -m "%MSG%" > commit_log.txt 2>&1

if %ERRORLEVEL%==0 (
    echo [SUCCES] Tout est en ligne !
    if exist commit_log.txt del commit_log.txt
    echo.
    echo [4/5] Verification de la sauvegarde...
    call "C:\dev\common\scripts\backup_svn.bat" silent
) else (
    echo [ERREUR] Le commit a echoue.
    echo --- Details de l erreur ---
    type commit_log.txt
)

pause
